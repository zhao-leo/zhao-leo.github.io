    <summary type="html">&lt;h1&gt;一道数列极限&lt;/h1&gt;
&lt;h2 id=&quot;题目如下：&quot;&gt;题目如下：&lt;/h2&gt;
&lt;p&gt;求下列数列极限：&lt;/p&gt;
&#92;lim_{n &#92;to &#92;infty} &#92;left ( &#92;frac{1}{n^{3}+1 }+ &#92;frac{4}{n^{3}+2 }+&#92;dots+&#92;frac{n^{2} }{n^{3}+n } &#92;right )

&lt;h2 id=&quot;解答：&quot;&gt;解答：&lt;/h2&gt;
&lt;h3 id=&quot;第一步：&quot;&gt;第一步：&lt;/h3&gt;
&#92;lim_{n &#92;to &#92;infty} &#92;left ( &#92;frac{1}{n^{3}+1 }+ &#92;frac{4}{n^{3}+2 }+&#92;dots+&#92;frac{n^{2} }{n^{3}+n } &#92;right )&gt;&#92;&#92;
&#92;lim_{n &#92;to &#92;infty} &#92;left ( &#92;frac{1}{n^{3}+n }+ &#92;frac{4}{n^{3}+n }+&#92;dots+&#92;frac{n^{2} }{n^{3}+n } &#92;right )=&#92;&#92;
&#92;lim_{n &#92;to &#92;infty} &#92;left ( &#92;frac{&#92;frac{1}{6}&#92;times n&#92;times &#92;left ( n+1 &#92;right ) &#92;times &#92;left ( 2n+1 &#92;right )  }{n^{3}+n } &#92;right )=&#92;frac{1}{3}</summary>
    
    
    
